{
  "name": "server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "NODE_ENV=production bun run src/index.ts",
    "build": "echo 'server runs directly with bun'",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:seed": "bun run src/db/seed.ts",
    "typecheck": "tsc --noEmit",
    "release:build": "bun run --cwd ../web build && bun build src/cli.ts --outfile=dist/cli.js --target=bun --minify && bun run scripts/prepare-dist.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "@workspace/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.29",
    "nanoid": "^5.1.16"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "~6"
  }
}
