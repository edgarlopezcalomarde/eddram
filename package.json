{
  "name": "eddram",
  "version": "0.1.0",
  "description": "Constructor visual de esquemas y diagramas ASCII. Monorepo root con server, web, shared y UI.",
  "private": true,
  "author": "Edgar Lopez Calomarde",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:migrate": "bun run --cwd apps/server db:migrate",
    "db:generate": "bun run --cwd apps/server db:generate",
    "db:seed": "bun run --cwd apps/server db:seed"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.18",
    "typescript": "~6"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.2",
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
